#, kde-format
msgid "Open website of <b>%1</b> in your browser."
msgstr "ເປີດເວັບໄຊຂອງ <b>%1</b> ໃນບຣາວເຊີຂອງທ່ານ."

#: kmymoney/views/simpleledgerview.cpp:996
#, kde-format
msgid ""
"You cannot close this view because you are reconciling the account. Finish, "
"cancel or postpone the reconciliation first."
msgstr ""
"ທ່ານບໍ່ສາມາດປິດມຸມມອງນີ້ໄດ້ ເພາະວ່າທ່ານກຳລັງປັບຍອດບັນຊີຢູ່. ໃຫ້ສຳເລັດ, ຍົກເລີກ ຫຼື "
"ເລື່ອນການປັບຍອດອອກໄປກ່ອນ."

#: kmymoney/views/simpleledgerview.cpp:997
#, kde-format
msgctxt "@title:info In reconciliation"
msgid "View cannot be closed"
msgstr "ມຸມມອງບໍ່ສາມາດປິດໄດ້"

#. i18n: ectx: property (text), widget (QLabel, l2)
#: kmymoney/views/simpleledgerview.ui:72
#, kde-format
msgid ""
"<html><head/><body><p>Once an account or category is selected its "
"transactions will be presented here.</p></body></html>"
msgstr ""
"<html><head/><body><p>ເມື່ອເລືອກບັນຊີ ຫຼື ປະເພດແລ້ວ ທຸລະກຳຂອງມັນຈະສະແດງຢູ່ນີ້.</p></body></"
"html>"

#. i18n: ectx: property (text), widget (QLabel, l3)
#: kmymoney/views/simpleledgerview.ui:85
#, kde-format
msgid ""
"<html><head/><body><p>Accounts marked as favorites will be opened "
"automatically after KMyMoney opened the file or database. Use the + button "
"on the tabbar above to select an account.</p></body></html>"
msgstr ""
"<html><head/><body><p>ບັນຊີທີ່ໝາຍເປັນລາຍການໂປດຈະຖືກເປີດໂດຍອັດຕະໂນມັດ ຫຼັງຈາກ KMyMoney "
"ເປີດໄຟລ໌ ຫຼື ຖານຂໍ້ມູນແລ້ວ. ໃຫ້ໃຊ້ປຸ່ມ + ຢູ່ແຖບດ້ານເທິງເພື່ອເລືອກບັນຊີ.</p></body></html>"

