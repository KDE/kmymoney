#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_writeEventsVsTodos)
#: kmymoney/plugins/icalendar/export/icalendarsettingsdecl.ui:34
#, kde-format
msgid ""
"Write the iCalendar file so that the entries are recognized by Google "
"Calendar."
msgstr "ຂຽນໄຟລ໌ iCalendar ເພື່ອໃຫ້ລາຍການຖືກຮັບຮູ້ໂດຍ Google Calendar."

#. i18n: ectx: property (whatsThis), widget (QCheckBox, kcfg_writeEventsVsTodos)
#: kmymoney/plugins/icalendar/export/icalendarsettingsdecl.ui:37
#, kde-format
msgid ""
"<html><head/><body><p>Write the iCalendar file so that the entries are "
"recognized by Google Calendar. The default is to write <a href=\"https://"
"icalendar.org/iCalendar-RFC-5545/3-6-2-to-do-component.html\">VTODO</a> "
"entries into the iCalendar file but for Google Calendar entries of type <a "
"href=\"https://icalendar.org/iCalendar-RFC-5545/3-6-1-event-component.html"
"\">VEVENT</a> are needed.</p></body></html>"
msgstr ""
"<html><head/><body><p>ຂຽນໄຟລ໌ iCalendar ເພື່ອໃຫ້ລາຍການຖືກຮັບຮູ້ໂດຍ Google Calendar. "
"ຄ່າເລີ່ມຕົ້ນແມ່ນຂຽນລາຍການ <a href=\"https://icalendar.org/iCalendar-RFC-5545/3-6-2-"
"to-do-component.html\">VTODO</a> ລົງໃນໄຟລ໌ iCalendar ແຕ່ສຳລັບ Google Calendar "
"ຕ້ອງການລາຍການປະເພດ <a href=\"https://icalendar.org/iCalendar-RFC-5545/3-6-1-"
"event-component.html\">VEVENT</a>.</p></body></html>"

