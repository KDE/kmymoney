<sect2 id="reference.menus.transaction"
><title
>İşlem Menüsü</title>
<variablelist>
  <varlistentry>
    <term
><menuchoice
><shortcut
> <keycombo
>&Ctrl;&Ins;</keycombo
> </shortcut
> <guimenu
>İşlem</guimenu
><guimenuitem
>Yeni İşlem</guimenuitem
> </menuchoice
></term>
    <listitem>
      <para
>Yeni işlem ekler.</para>
    </listitem>
  </varlistentry>

  <varlistentry>
    <term
><menuchoice
><shortcut
> <keycombo
>&Ctrl;<keycap
>E</keycap
></keycombo
> </shortcut
> <guimenu
