    </listitem>
  </varlistentry>

  <varlistentry>
    <term
><menuchoice
><guimenu
>Hesap</guimenu
><guimenuitem
>Hesap Eşlemesini Kaldır…</guimenuitem
> </menuchoice
></term>
    <listitem>
      <para
